# ---------------------------------------------------------------------------
# EcoComply backend configuration.  Copy to `.env` and fill in what you need.
# Everything has a safe default — the app runs fully offline with mocks.
# ---------------------------------------------------------------------------

# --- Relational database ---------------------------------------------------
# Default is a local SQLite file so it runs with zero setup.
# For the "full spec" Postgres setup, use e.g.:
#   DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/ecocomply
DATABASE_URL=sqlite:///./ecocomply.db

# --- Vector store (ChromaDB) ----------------------------------------------
CHROMA_DIR=./.chroma

# --- LLM provider ----------------------------------------------------------
# LLM_PROVIDER: "openrouter" (default) | "watsonx"
LLM_PROVIDER=openrouter

# OpenRouter (required when LLM_PROVIDER=openrouter) — add your key here:
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# IBM watsonx (only used when LLM_PROVIDER=watsonx)
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=https://eu-de.ml.cloud.ibm.com
WATSONX_MODEL_ID=ibm/granite-13b-instruct-v2

# --- Alerts (Twilio) -------------------------------------------------------
# ALERTS_PROVIDER: "mock" (default, logs only) | "twilio"
ALERTS_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TEST_TO_NUMBER=

# --- Scheduler -------------------------------------------------------------
# Daily MCP sync time (24h, server local time). Set ENABLE_SCHEDULER=false to disable.
ENABLE_SCHEDULER=true
SYNC_HOUR=0
SYNC_MINUTE=0

# --- CORS ------------------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:3000
