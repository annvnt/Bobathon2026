# EUR-Lex SOAP (https://eur-lex.europa.eu)
EURLEX_USER=
EURLEX_PASSWORD=

# Bundestag DIP REST (https://search.dip.bundestag.de)
BUNDESTAG_DIP_KEY=

# Open Legal Data (https://de.openlegaldata.io/pages/api/)
# Optional API key for higher rate limits; GET /laws/ works without auth
OPENLEGALDATA_API_KEY=

# Twilio alerts (optional — leave blank or set SKIP_TWILIO=1 to test without SMS)
SKIP_TWILIO=1
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Route all alerts to your test number (recommended for demo)
ALERT_TO_OVERRIDE=

# Optional escalation target for unknown Twilio replies
SUPPORT_EMAIL=
